{
  "name": "planning-poker",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:integration": "firebase emulators:exec --only firestore,auth 'vitest run --config vitest.integration.config.ts --passWithNoTests'",
    "emu": "firebase emulators:start --only firestore,auth",
    "lint:types": "vue-tsc -b --noEmit"
  },
  "dependencies": {
    "emoji-picker-element": "^1.29.1",
    "firebase": "^12.13.0",
    "lottie-web": "^5.13.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.32",
    "vue-i18n": "^11.4.2",
    "vue-router": "^5.0.6"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^24.12.2",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/test-utils": "^2.4.10",
    "@vue/tsconfig": "^0.9.1",
    "firebase-tools": "^15.17.0",
    "happy-dom": "^20.9.0",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.2",
    "vite": "^8.0.10",
    "vitest": "^4.1.5",
    "vue-tsc": "^3.2.7"
  }
}
